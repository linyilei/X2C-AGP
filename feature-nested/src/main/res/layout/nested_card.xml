<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="#E8F6EA"
    android:padding="12dp"
    tools:x2c="standard">

    <TextView
        android:id="@+id/nested_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="feature-nested transitive library"
        android:textColor="#124522"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/nested_badge"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/nested_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="#287D3C"
        android:paddingLeft="8dp"
        android:paddingTop="3dp"
        android:paddingRight="8dp"
        android:paddingBottom="3dp"
        android:text="A→B→C"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        app:layout_constraintBaseline_toBaselineOf="@id/nested_title"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/nested_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="app 只依赖 feature-demo；这个布局来自 feature-demo 的下游模块。"
        android:textColor="#376346"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="@id/nested_badge"
        app:layout_constraintStart_toStartOf="@id/nested_title"
        app:layout_constraintTop_toBottomOf="@id/nested_title" />

</androidx.constraintlayout.widget.ConstraintLayout>
